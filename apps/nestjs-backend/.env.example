NODE_ENV=development

PORT=4000
ENABLE_SWAGGER=true

FRONTEND_HOST=http://localhost:3000

# ========================================
# Database & Cache (Single-Entry URLs)
# Credentials must match root .env infrastructure config
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fullstack_vite_starter
REDIS_URL=redis://:redis_pass@127.0.0.1:6379

# MikroORM Debug
POSTGRES_DEBUG_MODE=false

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ========================================
# AI Services - DMXAPI (Image Generation)
# ========================================
DMX_API_KEY=your-dmx_api_key_here
EVOLINK_API_KEY=your_evolink_api_key_here